# ═══════════════════════════════════════════════════════════════════════════════
# PumpDev Jupiter Telegram — Example Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_BOT_TOKEN=                                          # GrammY bot token for sending trade reports
TELEGRAM_CHAT_ID=                                            # Telegram chat ID where reports are delivered

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener (MTProto Client)                               │
# └─────────────────────────────────────────────────────────────────────────────┘
# Both channels are optional. Set TELEGRAM_API_ID + TELEGRAM_API_HASH to enable.

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL_USERNAME=AveSolanaTokenScanner               # Primary channel (Ave Scanner format)
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL2_USERNAME=AveSignalMonitor                   # Secondary channel (Ave Signal Monitor format)
TELEGRAM_CHANNEL2_ID=
TELEGRAM_SESSION_NAME=telegram_session
TG_CONNECTION_RETRIES=5
TG_RETRY_DELAY_MS=5000
TG_AUTH_TIMEOUT_MS=300000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Paper Wallet                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

PAPER_BALANCE_SOL=0.5                                        # Starting paper wallet balance in SOL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing                                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

POSITION_SIZE_SOL=0.01
MAX_POSITION_SOL=0.1
MAX_OPEN_POSITIONS=999                                        # Effectively unlimited
SIGNAL_QUEUE_MAX_SIZE=50
SIGNAL_QUEUE_TTL_MS=600000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — Stop Loss / Trailing Stop                               │
# └─────────────────────────────────────────────────────────────────────────────┘

STOP_LOSS_PERCENT=-25                                        # Stop loss as negative percentage
TAKE_PROFIT_PERCENT=500                                      # Full TP target (5x)
TRAILING_ACTIVATION_PERCENT=20                               # Gain % before trailing activates
TRAILING_STOP_PERCENT=12                                     # Trail distance % below peak

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — TTL                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

BASE_TTL_SECS=3600                                            # 1 hour before TTL expiry check
MAX_TTL_SECS=10800                                            # Hard max position age (3 hours)
TTL_RENEW_THRESHOLD_PERCENT=8                                 # Price change % to auto-renew TTL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — Partial TP                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

# Semicolon-separated tiers: profit%,sell%;profit%,sell%
# Example:  30,25;60,25;100,50   → sell 25% at +30%, 25% at +60%, 50% at +100%
PARTIAL_TP_TIERS=100,25;200,25;500,25                         # 25%@2x, 25%@3x, 25%@6x

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data Streams — CabalSpy                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

CABALSPY_API_KEY=                                              # CabalSpy API key for signal stream

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data Streams — Jupiter                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

JUPITER_API_KEY=                                              # Jupiter API key (required for Price API v3)
JUPITER_BASE_URL=https://api.jup.ag/swap/v2                   # Jupiter Swap API

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Polling & Storage                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

PRICE_POLL_INTERVAL_MS=5000                                   # Price feed poll interval
POSITION_SCAN_INTERVAL_MS=5000                                # Strategy scan + pipeline process interval
DB_PATH=./data/trades.db                                      # SQLite database path

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  General                                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

LOG_LEVEL=info                                                # debug | info
