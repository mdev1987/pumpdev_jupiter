# ═══════════════════════════════════════════════════════════════════════════════
# Bot Trade Bot — Example Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_BOT_TOKEN=                                          # GrammY bot token for sending trade reports
TELEGRAM_CHAT_ID=                                            # Telegram chat ID where reports are delivered

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Connection (MTProto Client)                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

TG_CONNECTION_RETRIES=5
TG_RETRY_DELAY_MS=5000
TG_AUTH_TIMEOUT_MS=300000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_API_ID=                                              # MTProto API ID from my.telegram.org
TELEGRAM_API_HASH=                                            # MTProto API hash from my.telegram.org
TELEGRAM_CHANNEL_USERNAME=AveSolanaTokenScanner               # Active signal source channel
TELEGRAM_CHANNEL_ID=                                          # Resolved on first connect (optional)
TELEGRAM_SESSION_NAME=telegram_session

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Paper Wallet                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

PAPER_BALANCE_SOL=0.5                                        # Starting paper wallet balance in SOL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing                                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

POSITION_SIZE_SOL=0.01
MAX_POSITION_SOL=0.1
MAX_OPEN_POSITIONS=3
SIGNAL_QUEUE_MAX_SIZE=50
SIGNAL_QUEUE_TTL_MS=600000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — Stop Loss / Trailing Stop                               │
# └─────────────────────────────────────────────────────────────────────────────┘

STOP_LOSS_PERCENT=-15                                        # Stop loss as negative percentage
TAKE_PROFIT_PERCENT=200                                      # Not used by strategies (use PARTIAL_TP_TIERS)
TRAILING_ACTIVATION_PERCENT=15                               # Gain % before trailing activates (0 = off)
TRAILING_STOP_PERCENT=8                                      # Trail distance % below peak (0 = off)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — TTL                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

BASE_TTL_SECS=90                                              # Seconds before TTL expiry check
MAX_TTL_SECS=600                                              # Hard max position age in seconds
TTL_RENEW_THRESHOLD_PERCENT=8                                 # Price change % to auto-renew TTL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Exit Strategies — Partial TP                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

# Semicolon-separated tiers: profit%,sell%;profit%,sell%
# Example:  30,25;60,25;100,50   → sell 25% at +30%, 25% at +60%, 50% at +100%
PARTIAL_TP_TIERS=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data Streams — PumpDev                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

PUMPDEV_API_KEY=                                              # PumpDev API key
PUMPDEV_WS_URL=wss://pumpdev.io/ws
PUMPDEV_BASE_URL=https://pumpdev.io

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data Streams — Jupiter                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

JUPITER_API_KEY=                                              # Jupiter API key (required for Price API v3)
JUPITER_BASE_URL=https://api.jup.ag/swap/v2                   # Jupiter Swap API (unused, kept for reference)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Polling & Storage                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

PRICE_POLL_INTERVAL_MS=5000                                   # Price feed poll interval
POSITION_SCAN_INTERVAL_MS=5000                                # Strategy scan interval
DB_PATH=./data/trades.db                                      # SQLite database path

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  General                                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

LOG_LEVEL=info                                                # debug | info
