# ═══════════════════════════════════════════════════════════════════════════════
# Bot Trade Bot — Example Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_BOT_TOKEN=                                          # GrammY bot token for sending trade reports to Telegram
TELEGRAM_CHAT_ID=                                            # Telegram chat ID where reports are delivered

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Connection (MTProto Client)                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

TG_CONNECTION_RETRIES=5                                      # Number of MTProto connection retry attempts on failure
TG_RETRY_DELAY_MS=5000                                       # Delay in ms between MTProto connection retry attempts
TG_AUTH_TIMEOUT_MS=300000                                    # Timeout in ms for Telegram authentication input (5 min)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_API_ID=                                              # MTProto API ID from my.telegram.org
TELEGRAM_API_HASH=                                            # MTProto API hash from my.telegram.org
TELEGRAM_CHANNEL_USERNAME=AveSolanaTokenScanner               # Active signal source channel
TELEGRAM_CHANNEL_ID=                                          # Active channel numeric ID (optional, resolved on first connect)
TELEGRAM_SESSION_NAME=telegram_session                        # Session directory name for MTProto auth cache

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Paper Wallet                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

PAPER_BALANCE_SOL=0.5                                        # Starting paper wallet balance in SOL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing                                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

POSITION_SIZE_SOL=0.01                                       # Default position size in SOL for each trade
MAX_POSITION_SOL=0.1                                         # Max SOL per single position
MAX_OPEN_POSITIONS=3                                         # Max simultaneous open positions
SIGNAL_QUEUE_MAX_SIZE=50                                     # Max pending signals when at position limit
SIGNAL_QUEUE_TTL_MS=600000                                   # TTL for queued signals in ms (10 min)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Take-Profit / Stop-Loss                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

STOP_LOSS_PERCENT=-15                                        # Stop loss threshold as negative percentage
TAKE_PROFIT_PERCENT=200                                      # Take profit threshold as positive percentage
TRAILING_ACTIVATION_PERCENT=15                               # Gain percentage before trailing stop activates (0 = disabled)
TRAILING_STOP_PERCENT=8                                      # Trail distance percentage below peak price (0 = disabled)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position TTL                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

BASE_TTL_SECS=90                                              # Base TTL window in seconds before TTL check fires
MAX_TTL_SECS=600                                              # Maximum position age in seconds (hard cap)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  PumpDev API                                                               │
# └─────────────────────────────────────────────────────────────────────────────┘

PUMPDEV_API_KEY=                                              # API key for PumpDev lightning trading
PUMPDEV_WS_URL=wss://pumpdev.io/ws                            # PumpDev WebSocket URL
PUMPDEV_BASE_URL=https://pumpdev.io                           # PumpDev API base URL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Jupiter API                                                               │
# └─────────────────────────────────────────────────────────────────────────────┘

JUPITER_API_KEY=                                              # API key for Jupiter Swap API (optional)
JUPITER_BASE_URL=https://api.jup.ag/swap/v2                   # Jupiter Swap API base URL

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Price & Polling                                                           │
# └─────────────────────────────────────────────────────────────────────────────┘

PRICE_POLL_INTERVAL_MS=5000                                   # Interval in ms for polling position prices

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data Storage                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

DB_PATH=./data/trades.db                                      # Path to SQLite database file
